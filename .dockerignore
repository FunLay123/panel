# Dashboard: the frontend is prebuilt in CI (build.yml / build-dev.yml) and the
# compiled output is copied into the context as dashboard/build/. At runtime only
# the Python integration module and the compiled assets are used (build() never
# runs because dashboard/build/ already exists), so exclude all source/tooling.
# Excluding+re-including direct children avoids Docker's "can't re-include a file
# under an excluded parent directory" limitation.
dashboard/*
!dashboard/__init__.py
!dashboard/build

# Dockerfile.local (test/local image) builds the dashboard from source inside
# the container instead of using a CI-prebuilt dashboard/build/, so it needs
# these re-included too.
!dashboard/package.json
!dashboard/bun.lock
!dashboard/src
!dashboard/public
!dashboard/index.html
!dashboard/vite.config.mts
!dashboard/tsconfig.json
!dashboard/tsconfig.app.json
!dashboard/tsconfig.node.json
!dashboard/tailwind.config.js
!dashboard/components.json
!dashboard/react-router.config.ts
!dashboard/custom.d.ts
